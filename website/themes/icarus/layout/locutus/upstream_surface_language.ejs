<%
function surfacePercent(count, total) {
  if (!total || total <= 0) {
    return 0
  }
  return Math.max(0, Math.min(100, Math.round((count / total) * 1000) / 10))
}

// Sort namespaces: highest coverage first, then by wanted count desc, then alphabetical
var sortedNamespaces = surfaceLang.namespaces.slice().sort(function (a, b) {
  var aCov = a.coveragePercent || 0
  var bCov = b.coveragePercent || 0
  if (aCov !== bCov) return bCov - aCov
  var aWanted = a.wantedEntries ? a.wantedEntries.length : 0
  var bWanted = b.wantedEntries ? b.wantedEntries.length : 0
  if (aWanted !== bWanted) return bWanted - aWanted
  return (a.namespace || '').localeCompare(b.namespace || '')
})

// Group namespaces into meaningful buckets
var completeNamespaces = sortedNamespaces.filter(function (ns) {
  return ns.coveragePercent === 100
    || (ns.catalogShippedCount > 0 && (!ns.wantedEntries || ns.wantedEntries.length === 0) && (!ns.untriagedEntries || ns.untriagedEntries.length === 0))
})
var inProgressNamespaces = sortedNamespaces.filter(function (ns) {
  if (ns.coveragePercent === 100) return false
  if (ns.catalogShippedCount > 0 && (!ns.wantedEntries || ns.wantedEntries.length === 0) && (!ns.untriagedEntries || ns.untriagedEntries.length === 0)) return false
  return (ns.coveragePercent && ns.coveragePercent > 0) || (ns.wantedEntries && ns.wantedEntries.length > 0)
})
var triagedNamespaces = sortedNamespaces.filter(function (ns) {
  return (!ns.coveragePercent || ns.coveragePercent === 0)
    && (!ns.wantedEntries || ns.wantedEntries.length === 0)
    && (ns.skippedEntries && ns.skippedEntries.length > 0)
})
var untriagedNamespaces = sortedNamespaces.filter(function (ns) {
  return (!ns.coveragePercent || ns.coveragePercent === 0)
    && (!ns.wantedEntries || ns.wantedEntries.length === 0)
    && (!ns.skippedEntries || ns.skippedEntries.length === 0)
})
var groupCount = (completeNamespaces.length > 0 ? 1 : 0) + (inProgressNamespaces.length > 0 ? 1 : 0) + (triagedNamespaces.length > 0 ? 1 : 0) + (untriagedNamespaces.length > 0 ? 1 : 0)
var hasMultipleGroups = groupCount > 1
%>
<details class="surface-panel surface-panel-language surface-panel--toggle">
  <summary class="surface-panel__summary">
    <span class="surface-panel__summary-copy">
      <strong>Upstream Surface Inventory</strong>
      <span>
        <%= surfaceLang.catalogShippedCount %>/<%= surfaceLang.catalogCount %> shipped
        <% if (surfaceLang.wantedCount > 0) { %> &middot; <%= surfaceLang.wantedCount %> next<% } %>
        <% if (surfaceLang.untriagedCount > 0) { %> &middot; <%= surfaceLang.untriagedCount %> need triage<% } %>
      </span>
      <span class="surface-panel__summary-stack">
        <span class="surface-stack surface-stack--compact" aria-label="Upstream surface coverage">
          <% if (surfaceLang.catalogCount > 0) { %>
            <span class="surface-stack__segment surface-stack__segment--shipped" style="width: <%= surfacePercent(surfaceLang.catalogShippedCount, surfaceLang.catalogCount) %>%"></span>
            <% if (surfaceLang.wantedCount > 0) { %>
              <span class="surface-stack__segment surface-stack__segment--wanted" style="width: <%= surfacePercent(surfaceLang.wantedCount, surfaceLang.catalogCount) %>%"></span>
            <% } %>
            <% if (surfaceLang.skippedCount > 0) { %>
              <span class="surface-stack__segment surface-stack__segment--skipped" style="width: <%= surfacePercent(surfaceLang.skippedCount, surfaceLang.catalogCount) %>%"></span>
            <% } %>
            <% if (surfaceLang.untriagedCount > 0) { %>
              <span class="surface-stack__segment surface-stack__segment--untriaged" style="width: <%= surfacePercent(surfaceLang.untriagedCount, surfaceLang.catalogCount) %>%"></span>
            <% } %>
          <% } %>
        </span>
      </span>
    </span>
    <span class="surface-panel__summary-badge"><%= surfaceLang.coveragePercent === null ? 'n/a' : surfaceLang.coveragePercent + '%' %></span>
  </summary>

  <div class="surface-panel__content">
    <div class="surface-panel__intro">
      <div>
        <p>
          Locutus tracks <%= surfaceLang.namespaceCount %> upstream namespace<%= surfaceLang.namespaceCount === 1 ? '' : 's' %> for
          <%= surfaceLang.title || page.human || page.language %> and sorts them into what is already shipped,
          what we still want, what we intentionally keep, and what still needs a decision.
        </p>
        <% if (surfaceLang.scopeNote) { %>
          <p class="surface-summary"><%= surfaceLang.scopeNote %></p>
        <% } %>
      </div>
      <div class="surface-coverage-badge">
        <strong><%= surfaceLang.coveragePercent === null ? 'n/a' : surfaceLang.coveragePercent + '%' %></strong>
        <span>catalog shipped</span>
      </div>
    </div>

    <div class="surface-stack" aria-label="Upstream surface coverage">
      <% if (surfaceLang.catalogCount > 0) { %>
        <span class="surface-stack__segment surface-stack__segment--shipped" style="width: <%= surfacePercent(surfaceLang.catalogShippedCount, surfaceLang.catalogCount) %>%"></span>
        <% if (surfaceLang.wantedCount > 0) { %>
          <span class="surface-stack__segment surface-stack__segment--wanted" style="width: <%= surfacePercent(surfaceLang.wantedCount, surfaceLang.catalogCount) %>%"></span>
        <% } %>
        <% if (surfaceLang.skippedCount > 0) { %>
          <span class="surface-stack__segment surface-stack__segment--skipped" style="width: <%= surfacePercent(surfaceLang.skippedCount, surfaceLang.catalogCount) %>%"></span>
        <% } %>
        <% if (surfaceLang.untriagedCount > 0) { %>
          <span class="surface-stack__segment surface-stack__segment--untriaged" style="width: <%= surfacePercent(surfaceLang.untriagedCount, surfaceLang.catalogCount) %>%"></span>
        <% } %>
      <% } %>
    </div>

    <div class="surface-legend">
      <span><i class="surface-legend__swatch surface-legend__swatch--shipped"></i>Shipped</span>
      <% if (surfaceLang.wantedCount > 0) { %><span><i class="surface-legend__swatch surface-legend__swatch--wanted"></i>Next</span><% } %>
      <% if (surfaceLang.skippedCount > 0) { %><span><i class="surface-legend__swatch surface-legend__swatch--skipped"></i>Explicit non-goals</span><% } %>
      <% if (surfaceLang.untriagedCount > 0) { %><span><i class="surface-legend__swatch surface-legend__swatch--untriaged"></i>Needs triage</span><% } %>
    </div>

    <%/* Namespace mini-map: clickable tiles that filter the list */ %>
    <div class="surface-minimap">
      <% sortedNamespaces.forEach(function (ns) { %>
        <%
          var covClass = 'surface-minimap__tile--empty'
          var cov = ns.coveragePercent || 0
          if (cov >= 75) covClass = 'surface-minimap__tile--high'
          else if (cov >= 25) covClass = 'surface-minimap__tile--mid'
          else if (cov > 0) covClass = 'surface-minimap__tile--low'
          else if (ns.wantedEntries && ns.wantedEntries.length > 0) covClass = 'surface-minimap__tile--wanted'
        %>
        <span class="surface-minimap__tile <%= covClass %>"
              title="<%= ns.namespace %>: <%= cov %>% shipped"
              data-ns="<%= ns.namespace %>"
              onclick="(function(el){
                var input = el.closest('.surface-panel__content').querySelector('.surface-filter__input');
                if (!input) return;
                var ns = el.getAttribute('data-ns');
                if (input.value === ns) {
                  input.value = '';
                } else {
                  input.value = ns;
                }
                input.dispatchEvent(new Event('input'));
              })(this)">
          <span class="surface-minimap__name"><%= ns.namespace %></span>
          <span class="surface-minimap__pct"><%= cov %>%</span>
        </span>
      <% }) %>
    </div>

    <div class="surface-kpis">
      <article class="surface-kpi">
        <span class="surface-kpi__label">Tracked namespaces</span>
        <strong class="surface-kpi__value"><%= surfaceLang.namespaceCount %></strong>
      </article>
      <article class="surface-kpi">
        <span class="surface-kpi__label">Shipped</span>
        <strong class="surface-kpi__value"><%= surfaceLang.catalogShippedCount %>/<%= surfaceLang.catalogCount %></strong>
      </article>
      <% if (surfaceLang.wantedCount > 0) { %>
        <article class="surface-kpi">
          <span class="surface-kpi__label">Next to port</span>
          <strong class="surface-kpi__value"><%= surfaceLang.wantedCount %></strong>
        </article>
      <% } %>
      <% if (surfaceLang.untriagedCount > 0) { %>
        <article class="surface-kpi">
          <span class="surface-kpi__label">Needs triage</span>
          <strong class="surface-kpi__value"><%= surfaceLang.untriagedCount %></strong>
        </article>
      <% } %>
      <% if (surfaceLang.skippedCount > 0) { %>
        <article class="surface-kpi">
          <span class="surface-kpi__label">Explicit non-goals</span>
          <strong class="surface-kpi__value"><%= surfaceLang.skippedCount %></strong>
        </article>
      <% } %>
      <% if (surfaceLang.keptExtraCount > 0) { %>
        <article class="surface-kpi">
          <span class="surface-kpi__label">Intentional extras</span>
          <strong class="surface-kpi__value"><%= surfaceLang.keptExtraCount %></strong>
        </article>
      <% } %>
    </div>

    <%/* Filter input */ %>
    <div class="surface-filter">
      <input type="text" class="surface-filter__input" placeholder="Filter namespaces..." oninput="(function(el){
        var q = el.value.toLowerCase();
        var cards = el.closest('.surface-panel__content').querySelectorAll('.surface-card, .surface-compact-row');
        cards.forEach(function(c){
          var name = (c.getAttribute('data-namespace') || '').toLowerCase();
          c.style.display = (!q || name.indexOf(q) !== -1) ? '' : 'none';
        });
        var sections = el.closest('.surface-panel__content').querySelectorAll('.surface-ns-group');
        sections.forEach(function(s) {
          var visible = s.querySelectorAll('.surface-card:not([style*=&quot;display: none&quot;]), .surface-compact-row:not([style*=&quot;display: none&quot;])');
          s.style.display = visible.length ? '' : 'none';
        });
        var tiles = el.closest('.surface-panel__content').querySelectorAll('.surface-minimap__tile');
        tiles.forEach(function(t) {
          var isActive = q && t.getAttribute('data-ns').toLowerCase() === q;
          t.classList.toggle('surface-minimap__tile--active', isActive);
        });
      })(this)" />
    </div>

    <% if (completeNamespaces.length > 0) { %>
      <div class="surface-ns-group">
        <% if (hasMultipleGroups) { %>
          <h3 class="surface-ns-group__title">Complete</h3>
        <% } %>
        <% completeNamespaces.forEach(function (namespace) { %>
          <%- partial('locutus/upstream_surface_namespace', {
            page: page,
            namespace: namespace,
            showTitleLink: namespace.categories.length === 1,
            titleHref: namespace.categories.length === 1 ? url_for(page.language + '/' + namespace.categories[0] + '/') : null,
            compact: false
          }) %>
        <% }) %>
      </div>
    <% } %>

    <% if (inProgressNamespaces.length > 0) { %>
      <div class="surface-ns-group">
        <% if (hasMultipleGroups) { %>
          <h3 class="surface-ns-group__title">In progress</h3>
        <% } %>
        <% inProgressNamespaces.forEach(function (namespace) { %>
          <%- partial('locutus/upstream_surface_namespace', {
            page: page,
            namespace: namespace,
            showTitleLink: namespace.categories.length === 1,
            titleHref: namespace.categories.length === 1 ? url_for(page.language + '/' + namespace.categories[0] + '/') : null,
            compact: false
          }) %>
        <% }) %>
      </div>
    <% } %>

    <% if (triagedNamespaces.length > 0) { %>
      <div class="surface-ns-group">
        <h3 class="surface-ns-group__title">Triaged as out of scope</h3>
        <div class="surface-compact-list">
          <% triagedNamespaces.forEach(function (namespace) { %>
            <%- partial('locutus/upstream_surface_namespace', {
              page: page,
              namespace: namespace,
              showTitleLink: namespace.categories.length === 1,
              titleHref: namespace.categories.length === 1 ? url_for(page.language + '/' + namespace.categories[0] + '/') : null,
              compact: true
            }) %>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (untriagedNamespaces.length > 0) { %>
      <div class="surface-ns-group">
        <h3 class="surface-ns-group__title">Not yet triaged</h3>
        <div class="surface-compact-list">
          <% untriagedNamespaces.forEach(function (namespace) { %>
            <%- partial('locutus/upstream_surface_namespace', {
              page: page,
              namespace: namespace,
              showTitleLink: namespace.categories.length === 1,
              titleHref: namespace.categories.length === 1 ? url_for(page.language + '/' + namespace.categories[0] + '/') : null,
              compact: true
            }) %>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</details>
