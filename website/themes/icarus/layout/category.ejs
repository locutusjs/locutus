<% var curLang = '' %>
<% site.pages.find({ type: 'language', language: page.language }).each(function (lang) { %>
  <% curLang = lang %>
<% }) %>

<article class="article article-type-<%= page.layout %>" >
  <div class="article-inner">
    <header class="article-header">
      <h1 class="article-title"><%= page.title %></h1>
    </header>

    <div class="article-entry">
      <%
      var surfaceLang = site.data && site.data.upstream_surface && site.data.upstream_surface.languages
        ? site.data.upstream_surface.languages[page.language]
        : null;
      var surfaceNamespace = null;
      if (surfaceLang && surfaceLang.namespaces) {
        surfaceLang.namespaces.forEach(function (namespace) {
          if (namespace.namespace === page.category) {
            surfaceNamespace = namespace;
          }
        });
      }
      %>
      <ul>
        <% site.pages.find({ language: page.language, category: page.category, type: 'function' }).sort('function').each(function (func) { %>
          <li><a href="<%- url_for(func.path).replace('index.html', '') %>"><%- func.function %></a></li>
        <% }) %>
      </ul>

      <hr />
      <%- partial('locutus/add_more', {curLang: curLang}) %>

      <% if (surfaceNamespace) { %>
        <details class="surface-panel surface-panel--toggle surface-panel--namespace">
          <summary class="surface-panel__summary">
            <span class="surface-panel__summary-copy">
              <strong>Upstream Surface Inventory</strong>
              <span>
                <%= surfaceNamespace.catalogShippedCount %>/<%= surfaceNamespace.catalogEntries.length %> shipped
                <% if (surfaceNamespace.wantedEntries.length > 0) { %> • <%= surfaceNamespace.wantedEntries.length %> next<% } %>
                <% if (surfaceNamespace.untriagedEntries.length > 0) { %> • <%= surfaceNamespace.untriagedEntries.length %> need triage<% } %>
              </span>
              <span class="surface-panel__summary-stack">
                <span class="surface-stack surface-stack--compact" aria-label="Namespace coverage">
                  <% if (surfaceNamespace.catalogEntries.length > 0) { %>
                    <span class="surface-stack__segment surface-stack__segment--shipped" style="width: <%= Math.max(0, Math.min(100, Math.round((surfaceNamespace.catalogShippedCount / surfaceNamespace.catalogEntries.length) * 1000) / 10)) %>%"></span>
                    <% if (surfaceNamespace.wantedEntries.length > 0) { %>
                      <span class="surface-stack__segment surface-stack__segment--wanted" style="width: <%= Math.max(0, Math.min(100, Math.round((surfaceNamespace.wantedEntries.length / surfaceNamespace.catalogEntries.length) * 1000) / 10)) %>%"></span>
                    <% } %>
                    <% if (surfaceNamespace.skippedEntries.length > 0) { %>
                      <span class="surface-stack__segment surface-stack__segment--skipped" style="width: <%= Math.max(0, Math.min(100, Math.round((surfaceNamespace.skippedEntries.length / surfaceNamespace.catalogEntries.length) * 1000) / 10)) %>%"></span>
                    <% } %>
                    <% if (surfaceNamespace.untriagedEntries.length > 0) { %>
                      <span class="surface-stack__segment surface-stack__segment--untriaged" style="width: <%= Math.max(0, Math.min(100, Math.round((surfaceNamespace.untriagedEntries.length / surfaceNamespace.catalogEntries.length) * 1000) / 10)) %>%"></span>
                    <% } %>
                  <% } %>
                </span>
              </span>
            </span>
            <span class="surface-panel__summary-badge"><%= surfaceNamespace.coveragePercent === null ? 'n/a' : surfaceNamespace.coveragePercent + '%' %></span>
          </summary>
          <div class="surface-panel__content">
            <p class="surface-summary">
              Namespace-level inventory for <code><%= surfaceNamespace.target %></code>: what we already ship, what we may still want,
              and what we intentionally skip or keep.
            </p>
            <%- partial('locutus/upstream_surface_namespace', {
              page: page,
              namespace: surfaceNamespace,
              showTitleLink: false,
              titleHref: null,
              compact: false
            }) %>
          </div>
        </details>
      <% } %>

      <p>
        <a href="/<%= page.language %>/">&laquo; More <%= curLang.human %> functions</a>
      </p>
    </div>
  </div>
</article>
