<article id="<%= post.layout %>-<%= post.slug %>" class="article article-type-<%= post.layout %>" itemscope itemprop="blogPost">
    <div class="article-inner">
        <% if (post.banner) { %>
            <%- partial('post/banner') %>
        <% } %>
        <%- partial('post/gallery') %>
        <% if (post.link || post.title) { %>
            <header class="article-header">
                <%- partial('post/title', { class_name: 'article-title' }) %>
                <div class="article-meta">
                  <% if (typeof date !== 'undefined' && date === false) { %>
                    <%- partial('post/date', { class_name: 'article-date', date_format: null }) %>
                  <% } %>
                    <%- partial('post/category') %>
                    <%- partial('post/tag') %>
                </div>
            </header>
        <% } %>
        <div class="article-entry" itemprop="articleBody">
        <% if (index && post.excerpt) { %>
            <p><%- post.excerpt %></p>
            <p class="article-more-link">
                <a href="<%- url_for(post.path) %>#more"><%= __('article.more') %></a>
            </p>
        <% } else { %>
            <% if (!index && post.toc) { %>
                <div id="toc" class="toc-article">
                <strong class="toc-title"><%= __('article.catalogue') %></strong>
                    <%- toc(post.content) %>
                </div>
            <% } %>
            <%- post.content %>
        <% } %>
        </div>
        <% var showPostActions = (!index && post.layout === 'post'); %>
        <% var showIndexCommentCounter = index; %>
        <% if (showPostActions || showIndexCommentCounter) { %>
            <footer class="article-footer<%= showPostActions ? ' article-footer-post' : '' %>">
                <% if (showPostActions) { %>
                    <div class="article-social-actions">
                        <a href="https://x.com/locutus_io" class="twitter-follow-button" data-show-count="true" data-dnt="true">Follow @locutus_io</a>
                        <a class="github-button" href="https://github.com/locutusjs/locutus" data-size="large" data-show-count="true" aria-label="Star locutusjs/locutus on GitHub">Star</a>
                    </div>
                <% } else { %>
                    <%- partial('comment/counter', { post: post }) %>
                <% } %>
            </footer>
        <% } %>
    </div>
    <% if (!index) { %>
        <%- partial('post/nav') %>
    <% } %>
</article>

<% if (!index) { %>
    <%- partial('comment/index') %>
<% } %>
