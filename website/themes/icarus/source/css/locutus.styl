#profile
  width: 100%


.Social
    text-align: center

.widget-wrap-locutus_profile
  .avatar
    max-width: 80%
    display: block
    margin: auto auto

  .mission
    text-align: justify

.widget-on_the_githubs
  margin: 0
  padding: 15px 0

.on-the-githubs
  list-style: none
  margin: 0
  padding: 0

.on-the-githubs li
  list-style-type: none
  margin: 0 !important
  padding: 1px 0 !important
  border-bottom: none !important
  display: flex
  align-items: center
  gap: 4px
  overflow: hidden

  a:before
    content: none !important

  .otg-text
    flex: 1
    min-width: 0
    line-height: 16px
    font-size: 12px
    overflow: hidden
    white-space: nowrap
    text-overflow: ellipsis

  time
    font-size: 11px
    color: #999
    flex-shrink: 0
    white-space: nowrap

  a
    font-weight: normal

  img
    flex-shrink: 0
    border-radius: 10px
    width: 16px
    height: 16px


section.authors
  entry
    display: none

  li
    a:before
      content: ""


.article-entry blockquote:before
  content: ""
